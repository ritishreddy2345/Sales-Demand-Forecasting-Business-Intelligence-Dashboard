# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# GOOGLE CLOUD PLATFORM (GCP)
# ============================================================================

# Your GCP Project ID
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery Dataset name
GCP_DATASET_ID=sales_forecasting_db

# Path to service account JSON key (absolute path recommended)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# GCP Region
GCP_REGION=US

# ============================================================================
# PROJECT CONFIGURATION
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Number of synthetic records to generate (default: 50000)
NUM_SYNTHETIC_RECORDS=50000

# Number of days of historical data (default: 1095 = 3 years)
DATE_RANGE_DAYS=1095

# ============================================================================
# FORECASTING PARAMETERS
# ============================================================================

# Forecast horizon in days
FORECAST_HORIZON_DAYS=90

# Target forecast accuracy (0-1 scale, 0.87 = 87%)
TARGET_MAPE=0.87

# Prophet seasonality mode: additive or multiplicative
PROPHET_SEASONALITY_MODE=additive

# ============================================================================
# CUSTOMER SEGMENTATION
# ============================================================================

# Number of K-Means clusters
KMEANS_NUM_CLUSTERS=5

# ============================================================================
# NOTES
# ============================================================================
# 1. Get GCP_PROJECT_ID from: https://console.cloud.google.com/project
# 2. Create service account key:
#    - Go to: https://console.cloud.google.com/iam-admin/serviceaccounts
#    - Create service account
#    - Generate and download JSON key
#    - Save path as GOOGLE_APPLICATION_CREDENTIALS
# 3. Ensure service account has roles:
#    - BigQuery Admin (or BigQuery Data Editor + BigQuery ML Admin)
# 4. After setting this file, run: python main.py
